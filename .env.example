# Copy this file to .env and fill in your values.
# NEVER commit .env files to Git — they contain secrets.

# Supabase (publishable key is safe to expose; service_role is NOT)
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Supabase service role — server-side only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_LIVE_API_KEY=
STRIPE_SANDBOX_API_KEY=
VITE_PAYMENTS_CLIENT_TOKEN=

# Lovable
LOVABLE_API_KEY=

# Social feeds
VITE_BEHOLD_FEED_ID=

# Admin
ADMIN_DASHBOARD_PASSWORD=
